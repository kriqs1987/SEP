{
  "entities": {
    "WorkEvent": {
      "title": "WorkEvent",
      "description": "A single work shift or event.",
      "type": "object",
      "properties": {
        "date": { "type": "string", "description": "Date of the work event (YYYY-MM-DD)" },
        "start_time": { "type": "string", "description": "Start time (HH:MM)" },
        "end_time": { "type": "string", "description": "End time (HH:MM)" },
        "break_minutes": { "type": "number", "description": "Break duration in minutes" },
        "net_hours": { "type": "number", "description": "Net working hours calculated" },
        "payout_id": { "type": "string", "description": "ID of the associated payout, null if unpaid" },
        "created_at": { "type": "string", "description": "ISO timestamp of creation" }
      },
      "required": ["date", "start_time", "end_time", "break_minutes", "net_hours", "created_at"]
    },
    "Payout": {
      "title": "Payout",
      "description": "A settlement for a specific period.",
      "type": "object",
      "properties": {
        "date_from": { "type": "string", "description": "Start date of the settlement period" },
        "date_to": { "type": "string", "description": "End date of the settlement period" },
        "amount_net": { "type": "number", "description": "Net amount paid" },
        "amount_gross": { "type": "number", "description": "Gross amount paid" },
        "document_url": { "type": "string", "description": "Base64 encoded document or URL" },
        "created_at": { "type": "string", "description": "ISO timestamp of creation" }
      },
      "required": ["date_from", "date_to", "amount_net", "amount_gross", "created_at"]
    },
    "Settings": {
      "title": "Settings",
      "description": "User preferences for default work hours.",
      "type": "object",
      "properties": {
        "default_start_time": { "type": "string", "description": "Default start time (HH:MM)" },
        "default_end_time": { "type": "string", "description": "Default end time (HH:MM)" },
        "default_break_minutes": { "type": "number", "description": "Default break duration in minutes" }
      },
      "required": ["default_start_time", "default_end_time", "default_break_minutes"]
    }
  },
  "firestore": {
    "/users/{userId}/work_events/{eventId}": {
      "schema": { "$ref": "#/entities/WorkEvent" },
      "description": "Work events for a specific user."
    },
    "/users/{userId}/payouts/{payoutId}": {
      "schema": { "$ref": "#/entities/Payout" },
      "description": "Payouts for a specific user."
    },
    "/users/{userId}/settings/{settingId}": {
      "schema": { "$ref": "#/entities/Settings" },
      "description": "Settings for a specific user. Usually just one document 'default'."
    }
  }
}
